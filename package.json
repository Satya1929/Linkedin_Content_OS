    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bullmq": "^5.47.2",
    "ioredis": "^5.6.1",
    "lucide-react": "^0.488.0",
    "next": "^15.3.1",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.3.1",
    "prisma": "^6.6.0",
    "typescript": "^5.8.3",
    "vercel": "^53.1.0",
    "vitest": "^3.1.1"
  }
